<div class="container my-5  ms-6 d-flex justify-content-center">
  <div class="card shadow-sm border border-dark rounded w-100" style="max-width: 900px;"> 
    <div class="card-header bg-white py-3 border-bottom border-dark text-center">
      <h3 class="mb-0 fw-bold"><i class="bi bi-cart3 me-2 text-primary"></i>Your Shopping Cart</h3>
    </div>
    
    <div class="card-body p-0">
      <% let grandTotal = 0; %>
      
      <% if (!cart || cart.length === 0) { %>
        <div class="p-5 text-center">
          <p class="text-muted fs-5">Your cart is empty 🛒</p>
          <a href="/" class="btn btn-primary px-4">Go for Shopping</a>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table align-middle mb-0 mx-auto" style="border:2px solid #333; border-collapse: collapse; font-size: 1.1rem; text-align: center;">
            <thead class="table-light">
              <tr>
                <th style="border:1px solid #333; padding: 12px;">Product</th>
                <th style="border:1px solid #333; padding: 12px;">Price</th>
                <th style="border:1px solid #333; padding: 12px;">Quantity</th>
                <th style="border:1px solid #333; padding: 12px;">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% cart.forEach(item => { %>
                <% const total = item.price * item.qty; %>
                <% grandTotal += total; %>
                <tr>
                  <td style="border:1px solid #333; padding: 12px;">
                    <div class="d-flex align-items-center justify-content-center">
                      <img src="<%= item.image %>" class="rounded border border-dark me-3" style="width: 60px; height: 60px; object-fit: cover;">
                      <span class="fw-bold text-dark"><%= item.name %></span>
                    </div>
                  </td>
                  <td style="border:1px solid #333; padding: 12px;">₹<%= item.price %></td>
                  <td style="border:1px solid #333; padding: 12px;">
                    <span class="badge bg-primary px-3 py-2 rounded-pill"><%= item.qty %></span>
                  </td>
                  <td style="border:1px solid #333; padding: 12px; font-weight: 600;">₹<%= total %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <% if (cart && cart.length > 0) { %>
      <div class="card-footer bg-light p-4 border-top border-dark">
        <div class="row align-items-center">
          <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
            <a href="/" class="text-decoration-none fw-semibold text-primary">
              <i class="bi bi-arrow-left me-1"></i> Continue Shopping
            </a>
          </div>
          <div class="col-md-6 text-center text-md-end">
            <h4 class="fw-bold text-dark mb-3">Grand Total: <span class="text-success">₹<%= grandTotal %></span></h4>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>